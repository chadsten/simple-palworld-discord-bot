# =============================================================================
# DISCORD BOT CONFIGURATION
# =============================================================================

# Bot Token - Found in Discord Developer Portal > Bot section > Token
# https://discord.com/developers/applications -> Your App -> Bot -> Reset Token
DISCORD_TOKEN=your_bot_token_here

# Application ID - Found in Discord Developer Portal > General Information > Application ID  
# (Also called "Client ID" in some contexts)
CLIENT_ID=your_application_id_here

# Server ID - Right-click your Discord server icon and "Copy ID"
# (Developer Mode must be enabled in Discord > User Settings > Advanced)
GUILD_ID=your_guild_id_here

# Role name required to use bot commands (case-insensitive)
# Optional - defaults to: palserver
PALSERVER_ROLE_NAME=palserver

# Role name required for the admin commands /palannounce, /palsave and /palkill
# (case-insensitive). Admins can also use every base command.
# Optional - defaults to: palserver-admin
# PALSERVER_ADMIN_ROLE_NAME=palserver-admin

# Channel ID for background auto-stop announcements (optional).
# When set, the bot posts a message here when it auto-stops the empty server.
# Leave unset to disable monitor announcements.
ANNOUNCE_CHANNEL_ID=

# Name shown in announcements when you control the server from the host tray
# (default: Host). Set to your handle, e.g. Exo.
HOST_ACTOR_NAME=

# =============================================================================
# PALWORLD REST API CONFIGURATION  
# =============================================================================

# REST API endpoint for your Palworld server
PAL_REST_URL=http://127.0.0.1:8212/v1/api

# REST API credentials (set these in your Palworld server config)
# Note: PAL_REST_PASS should match your server's AdminPassword
PAL_REST_USER=admin
PAL_REST_PASS=your_admin_password_here

# =============================================================================
# PALWORLD SERVER MANAGEMENT
# =============================================================================

# Command to start your Palworld server (direct executable path).
#
# IMPORTANT: point this at PalServer-Win64-Shipping.exe (in Pal\Binaries\Win64),
# NOT the top-level PalServer.exe launcher. The launcher starts the "-Cmd" console
# variant, which opens its own visible console window that the bot cannot hide or
# capture. The Shipping.exe (non-Cmd) binary runs hidden AND writes to
# logs/palserver.log (viewable via the tray's "Open Game Logs").
#
# QUOTING: wrap the WHOLE value in single quotes, exactly as below. dotenv treats
# a value that STARTS with a double quote as escape-expanded, turning \n and \r
# into real control characters - so D:\nitrado\... silently becomes D: + newline
# + itrado\... and the launch fails. Single quotes disable that; dotenv strips
# them and passes the inner double quotes (needed for the space in "Program
# Files") through untouched.
START_CMD='"C:\Program Files (x86)\Steam\steamapps\common\PalServer\Pal\Binaries\Win64\PalServer-Win64-Shipping.exe" -USEALLAVAILABLECORES -NoAsyncLoadingThread'

# Working directory for the start command (optional).
# An unquoted value gets no escape expansion, so plain backslashes are safe here.
# If you do quote it, use single quotes - never double, for the reason above.
START_CWD=

# Windows service name (optional, if running as service)
SERVICE_NAME=

# =============================================================================
# TIMING CONFIGURATION
# =============================================================================

# How long to wait for server startup before timing out (milliseconds)
START_TIMEOUT_MS=120000

# How often to check server status during operations (milliseconds)
POLL_INTERVAL_MS=3000

# Delay between graceful stop and restart during /palbounce (milliseconds)
# Default: 15000 = 15 seconds (range 1000-120000)
BOUNCE_DELAY_MS=15000

# How long to wait after a world save before shutting the server down, so the
# save is durably written to disk. Nothing documents whether the server's REST
# /shutdown saves on its way out, so the bot always saves first and waits. This
# is also the window in which a player joining late can still abort /palstop.
# Raising it makes stops safer but slower; every stop pays it.
# Default: 30000 = 30 seconds (range 0-120000)
# SAVE_SETTLE_MS=30000

# How long to wait for the server to actually go down after a REST shutdown
# before /palkill escalates to a force kill. Separate from START_TIMEOUT_MS,
# which is a startup budget. "Down" means both the REST API has gone silent AND
# no server process is left running - a silent API alone is not proof.
# Default: 45000 = 45 seconds (range 10000-300000)
# STOP_TIMEOUT_MS=45000

# =============================================================================
# AUTO-MONITOR CONFIGURATION
# =============================================================================

# How often the background monitor checks for empty servers (milliseconds)
# Default: 600000 = 10 minutes
MONITOR_INTERVAL_MS=600000

# Number of consecutive empty checks before triggering auto-stop
# Default: 2 (so with 10min intervals = 20min total before auto-stop)
EMPTY_CHECK_THRESHOLD=2

# =============================================================================
# SCHEDULED AUTO-RESTART (optional)
# =============================================================================
# When enabled, the bot restarts the server every RESTART_INTERVAL_HOURS of
# uptime: it warns in-game at 30, 20, 10, 5, 3, 2 and 1 minutes beforehand, then
# saves the world, waits SAVE_SETTLE_MS and shuts the server down cleanly - with
# players online if need be - and starts it again. It only force-kills if the
# clean shutdown does not take within STOP_TIMEOUT_MS. The warning schedule is
# fixed and not configurable. A restart that fails is not retried for a full
# RESTART_INTERVAL_HOURS.

# Master switch for the scheduled restart feature (true/false).
# Default: false (feature off).
# AUTO_RESTART_ENABLED=false

# Hours of server uptime between automatic restarts.
# Default: 6 (range 1-168). The 1-hour minimum is deliberate: the warnings start
# 30 minutes out, so a shorter interval would overlap the previous restart.
# RESTART_INTERVAL_HOURS=6

# =============================================================================
# STEAMCMD UPDATE-ON-START (optional)
# =============================================================================
# When enabled, /palstart and /palbounce (and the tray Start/Reboot) run a
# SteamCMD update check BEFORE launching the server, so it implicitly updates on
# every start. Best-effort: if the update fails the server still starts on its
# current build and the failure is surfaced in Discord + the logs.
#
# NO-OP unless BOTH UPDATE_ON_START=true AND STEAMCMD_PATH is set. STEAMCMD_PATH
# and STEAM_INSTALL_DIR must point at your local SteamCMD and the server install.

# Master switch for the update-on-start feature (true/false).
# Default: false (feature off).
UPDATE_ON_START=false

# Absolute path to steamcmd.exe. Leave empty to disable the feature entirely.
STEAMCMD_PATH=

# Steam app id of the Palworld dedicated server.
# Default: 2394010 (confirmed correct; only change if Steam ever reassigns it).
STEAM_APP_ID=2394010

# Directory SteamCMD updates into (the server files root).
# Leave empty to fall back to START_CWD.
STEAM_INSTALL_DIR=

# Kill the update if SteamCMD emits no output for this long (milliseconds). This
# is the hang detector - SteamCMD streams continuous progress, so silence means
# it wedged. Default: 120000 = 2 minutes (range 30000-600000).
UPDATE_STALL_TIMEOUT_MS=120000

# Hard wall-clock cap on the whole update regardless of output (milliseconds).
# Backstop for pathological cases. Default: 1800000 = 30 minutes (range 60000-3600000).
UPDATE_TIMEOUT_MS=1800000
