# =============================================================================
# DISCORD BOT CONFIGURATION
# =============================================================================

# Bot Token - Found in Discord Developer Portal > Bot section > Token
# https://discord.com/developers/applications -> Your App -> Bot -> Reset Token
DISCORD_TOKEN=your_bot_token_here

# Application ID - Found in Discord Developer Portal > General Information > Application ID  
# (Also called "Client ID" in some contexts)
CLIENT_ID=your_application_id_here

# Server ID - Right-click your Discord server icon and "Copy ID"
# (Developer Mode must be enabled in Discord > User Settings > Advanced)
GUILD_ID=your_guild_id_here

# Role name required to use bot commands (case-insensitive)
# Optional - defaults to: palserver
PALSERVER_ROLE_NAME=palserver

# Channel ID for background auto-stop announcements (optional).
# When set, the bot posts a message here when it auto-stops the empty server.
# Leave unset to disable monitor announcements.
ANNOUNCE_CHANNEL_ID=

# Name shown in announcements when you control the server from the host tray
# (default: Host). Set to your handle, e.g. Exo.
HOST_ACTOR_NAME=

# =============================================================================
# PALWORLD REST API CONFIGURATION  
# =============================================================================

# REST API endpoint for your Palworld server
PAL_REST_URL=http://127.0.0.1:8212/v1/api

# REST API credentials (set these in your Palworld server config)
# Note: PAL_REST_PASS should match your server's AdminPassword
PAL_REST_USER=admin
PAL_REST_PASS=your_admin_password_here

# =============================================================================
# PALWORLD SERVER MANAGEMENT
# =============================================================================

# Command to start your Palworld server (direct executable path).
#
# IMPORTANT: point this at PalServer-Win64-Shipping.exe (in Pal\Binaries\Win64),
# NOT the top-level PalServer.exe launcher. The launcher starts the "-Cmd" console
# variant, which opens its own visible console window that the bot cannot hide or
# capture. The Shipping.exe (non-Cmd) binary runs hidden AND writes to
# logs/palserver.log (viewable via the tray's "Open Game Logs").
#
# QUOTING: wrap the WHOLE value in single quotes, exactly as below. dotenv treats
# a value that STARTS with a double quote as escape-expanded, turning \n and \r
# into real control characters - so D:\nitrado\... silently becomes D: + newline
# + itrado\... and the launch fails. Single quotes disable that; dotenv strips
# them and passes the inner double quotes (needed for the space in "Program
# Files") through untouched.
START_CMD='"C:\Program Files (x86)\Steam\steamapps\common\PalServer\Pal\Binaries\Win64\PalServer-Win64-Shipping.exe" -USEALLAVAILABLECORES -NoAsyncLoadingThread'

# Working directory for the start command (optional).
# An unquoted value gets no escape expansion, so plain backslashes are safe here.
# If you do quote it, use single quotes - never double, for the reason above.
START_CWD=

# Windows service name (optional, if running as service)
SERVICE_NAME=

# =============================================================================
# TIMING CONFIGURATION
# =============================================================================

# How long to wait for server startup before timing out (milliseconds)
START_TIMEOUT_MS=120000

# How often to check server status during operations (milliseconds)
POLL_INTERVAL_MS=3000

# Delay between graceful stop and restart during /palbounce (milliseconds)
# Default: 15000 = 15 seconds (range 1000-120000)
BOUNCE_DELAY_MS=15000

# =============================================================================
# AUTO-MONITOR CONFIGURATION
# =============================================================================

# How often the background monitor checks for empty servers (milliseconds)
# Default: 600000 = 10 minutes
MONITOR_INTERVAL_MS=600000

# Number of consecutive empty checks before triggering auto-stop  
# Default: 2 (so with 10min intervals = 20min total before auto-stop)
EMPTY_CHECK_THRESHOLD=2
