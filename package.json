{
  "name": "palworld-discord-bot",
  "version": "1.5.0",
  "private": true,
  "type": "module",
  "bin": "src/main.js",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "node src/main.js",
    "build": "node scripts/brand-tray-exe.js && node scripts/make-ico.js && pkg . --output dist/exos-palworld-bot.exe && node scripts/set-exe-icon.js"
  },
  "pkg": {
    "targets": [
      "node22-win-x64"
    ],
    "outputPath": "dist",
    "sea": true,
    "assets": [
      ".env.example",
      "node_modules/trayicon/rsrcs/**/*",
      "assets/app.ico"
    ]
  },
  "dependencies": {
    "discord.js": "^14.16.3",
    "dotenv": "^16.4.5",
    "trayicon": "^1.2.2"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^6.21.0",
    "png-to-ico": "^3.0.2",
    "resedit": "^3.0.2",
    "sharp": "^0.35.3"
  }
}
